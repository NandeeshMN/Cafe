# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=cafe_db

# Auth
JWT_SECRET=your_jwt_secret_key
PORT=5000

# Brevo SMTP (https://app.brevo.com → SMTP & API → SMTP tab)
# SMTP login shown in the "Login" column — used for authentication ONLY
BREVO_SMTP_USER=your_brevo_smtp_login@smtp-brevo.com
# SMTP key generated in Brevo dashboard
BREVO_SMTP_KEY=your_brevo_smtp_key
# Verified sender email (Brevo → Senders & IP → Senders) — shown to recipients
BREVO_SENDER_EMAIL=your_verified_sender@example.com

# Frontend URL (no trailing slash)
FRONTEND_URL=http://localhost:5173

# Token expiry in minutes
TOKEN_EXPIRY_MINUTES=15
